# ─────────────────────────────────────────────────────────────────
# Emowave — Variables de entorno del backend (Producción)
# ─────────────────────────────────────────────────────────────────
# INSTRUCCIONES:
# 1. Copia este archivo: cp .env.example .env
# 2. Rellena cada valor
# 3. NUNCA subas el archivo .env al repositorio
# ─────────────────────────────────────────────────────────────────

PORT=
FRONTEND_URL=

# ─── SEGURIDAD ───────────────────────────────────────────────────
JWT_SECRET=
JWT_REFRESH_SECRET=
BCRYPT_ROUNDS=

ACCESS_TOKEN_EXPIRES=
REFRESH_TOKEN_EXPIRES=
COOKIE_SECURE=
COOKIE_SAMESITE=
COOKIE_DOMAIN=

# ─── CORREO ELECTRÓNICO (SMTP) ───────────────────────────────────
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# ─── LIMITADORES Y EXPIRACIONES ──────────────────────────────────
OTP_EXPIRATION_MINUTES=
RESET_PASSWORD_EXPIRATION_MINUTES=

MAX_LOGIN_ATTEMPTS=
OTP_MAX_ATTEMPTS=
ACCOUNT_LOCK_MINUTES=

# ─── ADMINISTRADOR ───────────────────────────────────────────────
ADMIN_EMAIL=
ADMIN_USERNAME=
ADMIN_NAME=
ADMIN_PASSWORD=

# ─── ANTHROPIC (IA) ──────────────────────────────────────────────
ANTHROPIC_API_KEY=
